{
  "version": 1,
  "description": "Catálogo data-driven del Visor geográfico. Edite la copia canónica en Stack_Martin/config/visor/catalog.json y sincronice aquí si no usa Docker.",
  "search": {
    "limit_per_source": 5
  },
  "search_extras": [
    {
      "id": "mun",
      "enabled": true,
      "table": "c_mun",
      "tipo": "Municipio",
      "name_column": "nomgeo",
      "id_column": "cve_mun",
      "geom_mode": "polygon",
      "scope": "estatal",
      "mun_filter": false
    }
  ],
  "groups": [
    {
      "id": "marco",
      "label": "Marco geoestadístico",
      "layers": [
        "locspunto",
        "locsatlas",
        "colonias",
        "ageb_urbanas",
        "ageb_rurales",
        "manzanas",
        "vialidades"
      ]
    },
    {
      "id": "infraestructura",
      "label": "Infraestructura",
      "layers": ["rnc"]
    },
    {
      "id": "servicios",
      "label": "Servicios e instalaciones",
      "layers": ["saneamiento_agua", "clues", "residuo_solido"]
    },
    {
      "id": "medio_fisico",
      "label": "Medio físico",
      "layers": ["uso_suelo", "hidro_corrientes", "hidro_cuerpos", "curvas_nivel"]
    },
    {
      "id": "denue",
      "label": "DENUE",
      "layers": [
        "denue_rastros",
        "denue_gasolinerias",
        "denue_gaseras",
        "denue_escuelas",
        "denue_hospitales",
        "denue_museos",
        "denue_cementerios",
        "denue_iglesias"
      ]
    }
  ],
  "layers": {
    "locspunto": {
      "label": "Localidades",
      "overlay_key": "locsPunto",
      "checkbox_id": "visorLocsPunto",
      "geometry": "point",
      "renderer": "overlay",
      "style_preset": "point_symbol",
      "style": { "icon_key": "locs_punto_pin" },
      "legend": {
        "iconItems": [{ "icon_key": "locs_punto_pin", "label": "Localidad" }]
      },
      "data": {
        "table": "c_loc_punto",
        "mun_filter": "cve_mun",
        "export_columns": [
          "gid", "cve_mun", "cvegeo", "nom_loc", "nom_mun", "ambito",
          "latitud", "longitud", "altitud", "pob_total", "pob_femeni", "pob_mascul"
        ]
      },
      "identify": { "template": "locs_punto" },
      "capabilities": { "export": ["kml", "shp"], "tabular": true, "spatial_analysis": true },
      "search": {
        "enabled": true,
        "tipo": "Localidad",
        "name_column": "nom_loc",
        "id_column": "cvegeo",
        "geom_mode": "point",
        "scope": "both"
      }
    },
    "locsatlas": {
      "label": "Localidades con amanzanamiento",
      "overlay_key": "locsAtlas",
      "checkbox_id": "visorLocsAtlas",
      "geometry": "polygon",
      "renderer": "overlay",
      "style_preset": "polygon_outline_detail",
      "style": {
        "color": "#3399ff",
        "halo_color": "#3399ff",
        "fill_hit_color": "#3399ff"
      },
      "legend": {
        "items": [
          { "kind": "line", "color": "#3399ff", "label": "Límite de localidad con amanzanamiento" }
        ]
      },
      "data": { "table": "c_l", "mun_filter": "cve_mun" },
      "identify": { "template": "locs_atlas" },
      "capabilities": { "export": ["kml", "shp"], "tabular": false, "spatial_analysis": true },
      "search": {
        "enabled": true,
        "tipo": "Localidad con amanzanamiento",
        "name_column": "nomgeo",
        "id_column": "cvegeo",
        "geom_mode": "polygon",
        "scope": "both"
      }
    },
    "colonias": {
      "label": "Colonias",
      "overlay_key": "colonias",
      "checkbox_id": "visorColonias",
      "geometry": "polygon",
      "renderer": "overlay",
      "style_preset": "polygon_outline_detail",
      "style": {
        "color": "#990000",
        "halo_color": "#990000",
        "fill_hit_color": "#990000"
      },
      "legend": {
        "items": [
          { "kind": "line", "color": "#990000", "label": "Límite de colonia o asentamiento" }
        ]
      },
      "data": { "table": "c_col_ase", "mun_filter": "cve_mun" },
      "identify": { "title": "Colonia", "fields": [{ "column": "nom_asen" }] },
      "capabilities": { "export": ["kml", "shp"], "tabular": false, "spatial_analysis": true },
      "search": {
        "enabled": true,
        "tipo": "Colonia/Asentamiento",
        "name_column": "nom_asen",
        "id_column": "cvegeo",
        "geom_mode": "polygon",
        "scope": "both"
      }
    },
    "ageb_urbanas": {
      "label": "AGEBS Urbanas",
      "overlay_key": "agebUrbanas",
      "checkbox_id": "visorAgebUrbanas",
      "geometry": "polygon",
      "renderer": "overlay",
      "style_preset": "polygon_outline_detail",
      "style": {
        "color": "#990000",
        "halo_color": "#990000",
        "fill_hit_color": "#990000"
      },
      "legend": {
        "items": [{ "kind": "line", "color": "#990000", "label": "AGEB urbana" }]
      },
      "data": { "table": "c_a", "mun_filter": "cve_mun" },
      "identify": { "title": "AGEB Urbana", "fields": [{ "column": "cvegeo" }] },
      "capabilities": { "export": ["kml", "shp"], "tabular": false, "spatial_analysis": true }
    },
    "ageb_rurales": {
      "label": "AGEBS Rurales",
      "overlay_key": "agebRurales",
      "checkbox_id": "visorAgebRurales",
      "geometry": "polygon",
      "renderer": "overlay",
      "style_preset": "polygon_outline_detail",
      "style": {
        "color": "#666600",
        "halo_color": "#666600",
        "fill_hit_color": "#666600"
      },
      "legend": {
        "items": [{ "kind": "line", "color": "#666600", "label": "AGEB rural" }]
      },
      "data": { "table": "c_ar", "mun_filter": "cve_mun" },
      "identify": { "title": "AGEB Rural", "fields": [{ "column": "cvegeo" }] },
      "capabilities": { "export": ["kml", "shp"], "tabular": false, "spatial_analysis": true }
    },
    "manzanas": {
      "label": "Manzanas",
      "overlay_key": "manzanas",
      "checkbox_id": "visorManzanas",
      "geometry": "polygon",
      "renderer": "overlay",
      "style_preset": "polygon_fill",
      "style": {
        "color": "rgb(245, 225, 145)",
        "outline_color": "rgb(150, 150, 150)",
        "opacity": 0.6,
        "minzoom": 14
      },
      "legend": {
        "items": [
          {
            "kind": "fill",
            "color": "rgb(245, 225, 145)",
            "outline": "rgb(150, 150, 150)",
            "label": "Manzana"
          }
        ]
      },
      "data": { "table": "c_m", "mun_filter": "cve_mun" },
      "identify": { "template": "manzanas" },
      "capabilities": { "export": ["kml", "shp"], "tabular": false, "spatial_analysis": true }
    },
    "vialidades": {
      "label": "Vialidades (Calles)",
      "overlay_key": "vialidades",
      "checkbox_id": "visorVialidades",
      "geometry": "line",
      "renderer": "overlay",
      "style_preset": "line_outline",
      "style": {
        "color": "rgb(140, 95, 55)",
        "halo_color": "rgb(140, 95, 55)",
        "width": 2,
        "halo_width": 4
      },
      "legend": {
        "items": [{ "kind": "line", "color": "rgb(140, 95, 55)", "label": "Vialidad municipal" }]
      },
      "data": {
        "table": "c_e",
        "mun_filter": "cve_mun",
        "export_columns": [
          "gid", "cve_mun", "cvegeo", "nomvial", "nomvial1", "tipo", "orden",
          "ambito", "carretera", "longitud", "velocidad", "condicion"
        ]
      },
      "identify": { "title": "Vialidad", "join": { "left": ["tipovial"], "right": ["nomvial"] } },
      "capabilities": { "export": ["kml", "shp"], "tabular": false, "spatial_analysis": true }
    },
    "rnc": {
      "label": "Red Nacional de Caminos",
      "overlay_key": "rnc",
      "checkbox_id": "visorRnc",
      "geometry": "line",
      "renderer": "overlay_composite",
      "style_preset": "rnc_tiered",
      "style": {
        "field": "tipo_vial",
        "default_color": "rgb(140, 95, 55)",
        "classes": [
          { "value": "Carretera", "color": "rgb(200, 0, 0)", "label": "Carretera" },
          { "value": "Periférico", "color": "rgb(235, 145, 60)", "label": "Periférico" },
          { "value": "Vereda", "color": "rgb(0, 0, 0)", "label": "Vereda" },
          { "value": "Camino", "color": "rgb(140, 95, 55)", "label": "Camino" }
        ],
        "zoom": { "troncal_min": 10, "detail_min": 12 },
        "tiers": [
          {
            "id": "estatal",
            "filter_values": ["Boulevard", "Camino", "Carretera", "Vereda"]
          },
          {
            "id": "troncal",
            "filter_values": [
              "Carretera",
              "Autopista",
              "Corredor",
              "Camino",
              "Periférico",
              "Circuito",
              "Circunvalación",
              "Boulevard",
              "Viaducto",
              "Calzada",
              "Enlace",
              "Vereda"
            ]
          },
          { "id": "detail" }
        ]
      },
      "legend": {
        "items": [
          { "kind": "line", "color": "rgb(200, 0, 0)", "label": "Carretera" },
          { "kind": "line", "color": "rgb(235, 145, 60)", "label": "Periférico" },
          { "kind": "line", "color": "rgb(0, 0, 0)", "label": "Vereda" },
          { "kind": "line", "color": "rgb(140, 95, 55)", "label": "Camino / otro" }
        ]
      },
      "data": {
        "table": "c_rnc",
        "from_sql_preset": "rnc_simplified",
        "mun_filter": "cve_mun"
      },
      "identify": { "template": "rnc" },
      "capabilities": { "export": ["kml", "shp"], "tabular": false, "spatial_analysis": true }
    },
    "saneamiento_agua": {
      "label": "Servicios de Agua y Saneamiento",
      "overlay_key": "saneamientoAgua",
      "checkbox_id": "visorSaneamientoAgua",
      "geometry": "point",
      "renderer": "overlay",
      "style_preset": "point_symbol_by_attribute",
      "style": {
        "field": "tipo",
        "size_profile": "standard_zoom",
        "max_scale": 2.63,
        "default_icon_key": "agua_default",
        "icon_rules": [
          {
            "value": "Obra de toma para la captación de agua",
            "partial": "obra de toma",
            "icon_key": "agua_obra_toma",
            "label": "Obra de toma para la captación de agua"
          },
          {
            "value": "Planta de potabilización",
            "partial": "potabiliz",
            "icon_key": "agua_potabilizacion",
            "label": "Planta de potabilización"
          },
          {
            "value": "Planta de tratamiento",
            "partial": "planta de trat",
            "icon_key": "agua_tratamiento",
            "label": "Planta de tratamiento"
          },
          {
            "value": "Prestador de Servicio de agua potable",
            "partial": "prestador",
            "icon_key": "agua_prestador",
            "label": "Prestador de servicio de agua potable"
          },
          {
            "value": "Punto de descarga",
            "partial": "descarga",
            "icon_key": "agua_descarga",
            "label": "Punto de descarga"
          }
        ]
      },
      "legend": {
        "iconItems": [
          { "icon_key": "agua_obra_toma", "label": "Obra de toma para la captación de agua" },
          { "icon_key": "agua_potabilizacion", "label": "Planta de potabilización" },
          { "icon_key": "agua_tratamiento", "label": "Planta de tratamiento" },
          { "icon_key": "agua_prestador", "label": "Prestador de servicio de agua potable" },
          { "icon_key": "agua_descarga", "label": "Punto de descarga" },
          { "icon_key": "agua_default", "label": "Otro servicio de agua o saneamiento" }
        ]
      },
      "data": { "table": "c_agua_sanea", "mun_filter": "cve_mun" },
      "identify": { "title": "Agua/saneamiento", "join": { "left": ["tipo"], "right": ["nom_tipo"] } },
      "capabilities": { "export": ["kml", "shp"], "tabular": false, "spatial_analysis": true }
    },
    "clues": {
      "label": "Establecimientos de salud",
      "overlay_key": "clues",
      "checkbox_id": "visorClues",
      "geometry": "point",
      "renderer": "overlay",
      "style_preset": "point_symbol",
      "style": { "icon_key": "clues_health" },
      "legend": {
        "iconItems": [{ "icon_key": "clues_health", "label": "Establecimiento de salud" }]
      },
      "data": {
        "table": "c_clues",
        "mun_filter": "cve_mun",
        "export_columns": ["gid", "cve_mun", "clues", "nom_insti", "nom_comer", "nom_insadm"]
      },
      "identify": { "template": "clues" },
      "capabilities": { "export": ["kml", "shp"], "tabular": true, "spatial_analysis": true },
      "search": {
        "enabled": true,
