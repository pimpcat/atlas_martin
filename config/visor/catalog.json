          { "icon_key": "residuo_recoleccion", "label": "Prestador de servicio de recolección" },
          { "icon_key": "residuo_default", "label": "Otro punto de residuos sólidos" }
        ]
      },
      "data": {
        "table": "c_residuo_solido",
        "mun_filter": "cve_mun",
        "export_columns": ["gid", "cve_mun", "cvegeo", "tipo", "nom_tipo"]
      },
      "identify": {
        "title": "Residuos solidos urbanos",
        "join": { "left": ["tipo"], "right": ["nom_tipo"] }
