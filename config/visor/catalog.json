        "default_icon_key": "residuo_default",
        "default_label": "Otro punto de residuos sólidos",
        "icon_rules": [
          {
            "value": "Sitio de disposición final de residuos",
            "partial": "disposici",
            "icon_key": "residuo_disposicion",
            "label": "Sitio de disposición final de residuos"
