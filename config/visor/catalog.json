        "scope": "municipio",
        "mun_filter": true,
        "mun_filter_cvegeo": false
      }
    },
    "residuo_solido": {
      "label": "Residuos solidos urbanos",
      "overlay_key": "residuoSolido",
      "checkbox_id": "visorResiduoSolido",
      "geometry": "point",
      "renderer": "overlay",
      "style_preset": "point_symbol_by_attribute",
      "style": {
        "field": "tipo",
        "size_profile": "residuo_zoom",
        "max_scale": 3.5,
        "supersample": 4,
        "layout": {
          "icon-offset": [0, 6]
